# Copy this to .env for local development
# Both services read these same vars

DASHBOARD_PASSWORD=your_password_here

# Local dev: use a relative path. Railway: set to /data (the volume mount point)
DATA_DIR=./data

# Dashboard → API connection
# Local dev: http://localhost:8000
# Railway:   http://zonal-eagerness.railway.internal:8000
API_URL=http://localhost:8000

# Telegram bot reminders (optional)
# Create a bot via @BotFather on Telegram to get the token
TELEGRAM_BOT_TOKEN=
# Timezone for the reminder scheduler (default: Asia/Kolkata)
TZ=Asia/Kolkata
